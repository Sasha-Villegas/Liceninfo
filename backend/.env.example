# ============================================
# Variables de Entorno - Liceninfo Backend
# ============================================
# Copia este archivo como .env y completá con tus datos

# --- SMTP (para enviar emails de alerta) ---
# Usa Gmail con App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# --- Google Gemini AI ---
# Obtené tu API key gratis en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# --- Puerto del servidor (Render lo asigna automáticamente) ---
PORT=8000
